{
  "name": "@dino/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "prisma db push && tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma db push && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "@prisma/client": "^6.6.0",
    "google-auth-library": "^9.15.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/cors": "^2.8.17",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "vitest": "^3.1.0"
  }
}
